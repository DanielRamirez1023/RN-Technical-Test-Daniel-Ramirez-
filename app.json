{
  "expo": {
    "name": "movies-app",
    "slug": "movies-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/splash-icon2.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon2.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "bundleIdentifier": "com.moviesapp.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocalNotificationUsageDescription": "This app uses local notifications to remind you to watch your favorite movies."
      }
    },
    "android": {
      "package": "com.moviesapp.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/splash-icon2.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#ffffff"
        }
      ],
      "expo-dev-client"
    ]
  }
}
